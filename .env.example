# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Gmail integration for sending outreach emails
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: Google Custom Search API (enhances web search)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional: Logging configuration
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=console      # console or json

# ChromaDB: No config needed — runs in embedded mode with local embeddings.
# First run downloads the embedding model (~80MB, cached at ~/.cache/chroma/).
# Requires Python 3.13 (ChromaDB does not support Python 3.14).
